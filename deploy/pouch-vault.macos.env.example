# pouch-vault macOS launchd env.
# Conventional location: ~/Library/Application Support/pouch-vault/vault.env
# `make local-install` copies this stub there on first install.
#
# Fill in the REPLACE_ME values, then `make local-restart`.

# Cloud endpoint
POUCH_URL=https://pouch.pointegrity.com

# Long-lived credentials minted by `pouch-vault pair` on first boot.
# Both lines must be present; shown ONCE by the pair flow.
POUCH_VAULT_KEY=REPLACE_ME
POUCH_HMAC_SECRET=REPLACE_ME

# Local storage. Conventionally under ~/Library/Application Support/
# pouch-vault/ so launchd's sandbox lets us write there without
# extra permissions.
VAULT_DB=__PREFIX__/data/drops.db
VAULT_BLOBS=__PREFIX__/data/blobs
VAULT_MIRROR=__PREFIX__/data/mirror

# Vault name (defaults to hostname if unset).
VAULT_NAME=macblack

# Local listener: pull-mode serves /healthz + the local UI.
# 127.0.0.1 only — no public surface. `make local-ui` opens it.
VAULT_LISTEN=127.0.0.1:17779

# Multi-folder declaration. The first entry below assumes you're
# producing drops from a real folder (direction=watch). For pure
# consumer mode, switch to direction=mirror.
VAULT_PATHS=[{"path":"__HOME__/ws/jyws/mytraces/data/raw","stream":"mytraces-raw","direction":"watch"}]

# Optional chunked-transfer pacing. Defaults: 4 MiB chunks + 250 ms
# inter-chunk sleep. Uncomment to override.
#VAULT_UPLOAD_CHUNK=4
#VAULT_UPLOAD_THROTTLE_MS=250
#VAULT_DOWNLOAD_THROTTLE_MS=250
