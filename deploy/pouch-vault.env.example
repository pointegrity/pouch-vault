# pouch-vault systemd env. Installed to /etc/default/pouch-vault
# with mode 0600 (holds the long-lived vault key + HMAC secret).
#
# Fill in the REPLACE_ME values after pairing.

# Cloud endpoint
POUCH_URL=https://pouch.pointegrity.com

# Long-lived credentials minted by `pouch-vault pair` on first boot.
# Both lines must be present; shown ONCE by the pair flow.
POUCH_VAULT_KEY=REPLACE_ME
POUCH_HMAC_SECRET=REPLACE_ME

# Local storage. Conventionally under ~/infra/pouch-vault/data so
# the systemd service's ReadWritePaths covers it cleanly.
VAULT_DB=/home/jy/infra/pouch-vault/data/drops.db
VAULT_BLOBS=/home/jy/infra/pouch-vault/data/blobs
VAULT_MIRROR=/home/jy/infra/pouch-vault/data/mirror

# Vault name (defaults to hostname if unset). Distinguishes this
# machine from other vaults on the same pouch account.
VAULT_NAME=rtx

# Local listener: pull-mode serves /healthz + the local UI.
# Set to "off" to disable. 127.0.0.1 only — no public surface.
VAULT_LISTEN=127.0.0.1:7780

# Multi-folder declaration. Each entry: {path, stream, direction?}.
#   direction='mirror' (default) — cloud delivers drops here
#   direction='watch'             — this vault scans for new files
#                                   and POSTs them as drops
# A single VAULT_PATHS entry can declare BOTH a path and a stream,
# but a vault either watches a path or mirrors it, not both for the
# same entry. For replication: this rtx vault is purely consumer
# (direction=mirror); the producing vault on another host has
# direction=watch on the source folder.
VAULT_PATHS=[{"path":"mytraces-raw","stream":"mytraces-raw","direction":"mirror"}]

# Optional: chunked-transfer pacing knobs (Phase 5 slice 8e). Defaults
# (4 MiB chunks + 250 ms inter-chunk sleep, both up and down) are
# conservative. Tune if needed.
#VAULT_UPLOAD_CHUNK=4
#VAULT_UPLOAD_THROTTLE_MS=250
#VAULT_DOWNLOAD_THROTTLE_MS=250
