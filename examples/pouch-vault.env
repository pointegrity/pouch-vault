# /etc/pouch/vault.env (mode 600, owner pouch:pouch)
#
# Values come from running `pouch vault create --owner <U> --name <N>`
# on the pouch server. They're shown once — paste them here and into
# this file's git-ignored cousin if you keep a deploy repo.

POUCH_URL=https://pouch.pointegrity.com
POUCH_VAULT_KEY=pk_REPLACE_ME
POUCH_HMAC_SECRET=REPLACE_ME

# Where pouch can reach this vault. Public hostname or a tunnel
# (cloudflared, tailscale funnel, frp, etc.). Path is /hook.
POUCH_PUBLIC_URL=https://vault.example/hook

# Local listener — bind to localhost only if you're fronting with
# cloudflared / nginx; bind to :7780 directly if exposed publicly.
VAULT_LISTEN=127.0.0.1:7780

# Local SQLite archive — pair with `litestream` for offsite backup
# if you want to survive disk loss without re-fetching from pouch.
VAULT_DB=/var/lib/pouch-vault/drops.db

# Optional. Defaults to `hostname`.
VAULT_NAME=
